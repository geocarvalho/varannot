<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>AlphaGenome Variant Report</title>
<style>
  :root {
    --ink: #1a1d24;
    --ink-soft: #5a6275;
    --paper: #fbfaf7;
    --panel: #ffffff;
    --line: #e3e0d8;
    --accent: #2b6f6a;
    --accent-soft: #e6f0ef;
    --warn: #b5532a;
    --gap: #b9b6ad;
    --mono: ui-monospace, "SF Mono", "JetBrains Mono", Menlo, Consolas, monospace;
    --sans: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0; background: var(--paper); color: var(--ink);
    font-family: var(--sans); line-height: 1.5; -webkit-font-smoothing: antialiased;
  }
  header.report-head {
    padding: 2.4rem 2rem 1.6rem; border-bottom: 2px solid var(--ink);
    display: flex; align-items: baseline; justify-content: space-between;
    flex-wrap: wrap; gap: 1rem;
  }
  header.report-head h1 { font-size: 1.5rem; font-weight: 650; margin: 0; letter-spacing: -0.01em; }
  header.report-head .meta { font-family: var(--mono); font-size: 0.78rem; color: var(--ink-soft); }
  .wrap { max-width: 1300px; margin: 0 auto; padding: 1.5rem 2rem 4rem; }

  .empty { color: var(--gap); font-style: italic; font-size: 0.9rem; }
  .err { color: var(--warn); font-size: 0.8rem; font-family: var(--mono); }
  a { color: var(--accent); }

  footer { padding: 2rem; text-align: center; color: var(--ink-soft); font-size: 0.76rem; }
</style>
{% include "_ag_styles.html.j2" %}
</head>
<body>
<header class="report-head">
  <h1>AlphaGenome Variant Report</h1>
  <div class="meta">
    {{ n_variants }} variant{{ "s" if n_variants != 1 else "" }} &middot;
    GRCh38 &middot; generated {{ generated }}
  </div>
</header>

<div class="wrap">
{% include "_ag_panel.html.j2" %}
</div>

<footer>
  Generated by varannot &middot; Predictions: AlphaGenome (Google DeepMind) &middot;
  Research use only; AlphaGenome predictions require expert interpretation.
</footer>

{% include "_ag_lightbox.html.j2" %}
</body>
</html>

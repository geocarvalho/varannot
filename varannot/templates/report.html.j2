<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Variant Annotation Report</title>
<style>
  :root {
    --ink: #1a1d24;
    --ink-soft: #5a6275;
    --paper: #fbfaf7;
    --panel: #ffffff;
    --line: #e3e0d8;
    --accent: #2b6f6a;        /* deep teal */
    --accent-soft: #e6f0ef;
    --warn: #b5532a;          /* terracotta for pathogenic flags */
    --warn-soft: #f7e9e2;
    --good: #3f7d4e;
    --match: #2b6f6a;
    --mismatch: #b5532a;
    --gap: #b9b6ad;
    --mono: ui-monospace, "SF Mono", "JetBrains Mono", Menlo, Consolas, monospace;
    --sans: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0; background: var(--paper); color: var(--ink);
    font-family: var(--sans); line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }
  header.report-head {
    padding: 2.4rem 2rem 1.6rem; border-bottom: 2px solid var(--ink);
    display: flex; align-items: baseline; justify-content: space-between;
    flex-wrap: wrap; gap: 1rem;
  }
  header.report-head h1 {
    font-size: 1.5rem; font-weight: 650; margin: 0; letter-spacing: -0.01em;
  }
  header.report-head .meta {
    font-family: var(--mono); font-size: 0.78rem; color: var(--ink-soft);
  }
  .wrap { max-width: 1100px; margin: 0 auto; padding: 1.5rem 2rem 4rem; }

  .variant-card {
    background: var(--panel); border: 1px solid var(--line);
    border-radius: 10px; margin: 1.6rem 0; overflow: hidden;
    box-shadow: 0 1px 2px rgba(20,29,36,0.04);
  }
  .variant-head {
    padding: 1.1rem 1.4rem; border-bottom: 1px solid var(--line);
    display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
    background: linear-gradient(to right, var(--accent-soft), transparent);
  }
  .variant-head .coord {
    font-family: var(--mono); font-size: 1.02rem; font-weight: 600;
    color: var(--ink);
  }
  .variant-head .gene {
    font-weight: 650; font-size: 1.05rem; color: var(--accent);
  }
  .badge {
    font-family: var(--mono); font-size: 0.72rem; text-transform: uppercase;
    letter-spacing: 0.04em; padding: 0.18rem 0.5rem; border-radius: 999px;
    border: 1px solid var(--line); color: var(--ink-soft); background: #fff;
  }
  .badge.path { color: var(--warn); border-color: var(--warn); background: var(--warn-soft); }
  .badge.benign { color: var(--good); border-color: var(--good); }

  .grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 0;
  }
  @media (max-width: 720px) { .grid { grid-template-columns: 1fr; } }
  .cell {
    padding: 1rem 1.4rem; border-bottom: 1px solid var(--line);
    border-right: 1px solid var(--line);
  }
  .cell:nth-child(2n) { border-right: none; }
  .cell h3 {
    margin: 0 0 0.5rem; font-size: 0.72rem; text-transform: uppercase;
    letter-spacing: 0.07em; color: var(--ink-soft); font-weight: 600;
  }
  .kv { display: flex; gap: 0.5rem; font-size: 0.9rem; margin: 0.16rem 0; }
  .kv .k { color: var(--ink-soft); min-width: 8.5rem; }
  .kv .v { font-family: var(--mono); color: var(--ink); word-break: break-word; }
  a { color: var(--accent); text-decoration: none; border-bottom: 1px solid var(--accent-soft); }
  a:hover { border-bottom-color: var(--accent); }

  .hgvs { font-family: var(--mono); font-size: 0.85rem; }
  .hgvs div { margin: 0.15rem 0; word-break: break-all; }

  /* conservation track */
  .track {
    font-family: var(--mono); font-size: 0.95rem; letter-spacing: 0.06em;
    line-height: 1.3; word-break: break-all; margin-top: 0.3rem;
  }
  .track .m { color: var(--match); }
  .track .x { color: var(--mismatch); font-weight: 700; }
  .track .g { color: var(--gap); }
  .track-legend { font-size: 0.72rem; color: var(--ink-soft); margin-top: 0.3rem; }

  .score-bar {
    height: 6px; background: var(--line); border-radius: 3px; overflow: hidden;
    margin-top: 0.3rem; max-width: 200px;
  }
  .score-bar > span { display: block; height: 100%; background: var(--accent); }
  .score-bar.path > span { background: var(--warn); }

  .empty { color: var(--gap); font-style: italic; font-size: 0.85rem; }
  .err { color: var(--warn); font-size: 0.8rem; font-family: var(--mono); }

  .gene-model { padding: 0.4rem 0 0.1rem; }
  .gene-model svg { display: block; max-width: 100%; }
  .gene-model .cap {
    font-size: 0.8rem; color: var(--ink-soft); margin-top: 0.25rem;
    display: flex; gap: 0.6rem; flex-wrap: wrap; align-items: baseline;
  }
  .gene-model .cap .pos { font-family: var(--mono); color: var(--ink); }
  .gene-model .legend {
    font-size: 0.7rem; color: var(--ink-soft); margin-top: 0.15rem;
  }
  .gene-model .legend .sw {
    display: inline-block; width: 0.7rem; height: 0.55rem; border-radius: 2px;
    vertical-align: middle; margin-right: 0.2rem;
  }

  table.gtex { width: 100%; border-collapse: collapse; font-size: 0.86rem; margin-top: 0.3rem; max-width: 640px; }
  table.gtex td { padding: 0.2rem 0.5rem 0.2rem 0; vertical-align: middle; }
  table.gtex td.tname { color: var(--ink); white-space: nowrap; width: 14rem; }
  table.gtex tr.extra td.tname { color: var(--ink-soft); }
  table.gtex td.tval { font-family: var(--mono); text-align: right; width: 4.5rem; color: var(--ink); }
  table.gtex .tag {
    font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.04em;
    color: var(--ink-soft); border: 1px solid var(--line); border-radius: 999px;
    padding: 0.02rem 0.32rem; margin-left: 0.25rem;
  }
  .gbar { background: var(--line); border-radius: 3px; height: 8px; overflow: hidden; }
  .gbar > span { display: block; height: 100%; background: var(--gap); }
  .gbar > span.top { background: var(--accent); }

  table.pheno { width: 100%; border-collapse: collapse; font-size: 0.84rem; margin-top: 0.3rem; }
  table.pheno td { padding: 0.22rem 0.4rem; border-bottom: 1px solid var(--line); vertical-align: top; }
  table.pheno td:first-child { color: var(--ink); }
  table.pheno td:last-child { font-family: var(--mono); color: var(--ink-soft); white-space: nowrap; }

  footer { padding: 2rem; text-align: center; color: var(--ink-soft); font-size: 0.76rem; }

  /* tabs (only rendered in the combined report) */
  .tabs {
    max-width: 1100px; margin: 0 auto; padding: 0.9rem 2rem 0;
    display: flex; gap: 0.4rem; border-bottom: 2px solid var(--ink);
  }
  .tab-btn {
    font-family: var(--sans); font-size: 0.88rem; font-weight: 600;
    border: 1px solid var(--line); border-bottom: none;
    background: var(--paper); color: var(--ink-soft);
    padding: 0.55rem 1.1rem; border-radius: 8px 8px 0 0; cursor: pointer;
    margin-bottom: -2px;
  }
  .tab-btn.active {
    background: var(--panel); color: var(--ink); border-color: var(--ink);
    border-bottom: 2px solid var(--panel);
  }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  /* floating report actions (web only) */
  .report-actions {
    position: fixed; bottom: 18px; right: 18px; z-index: 60;
    display: flex; gap: 0.5rem;
  }
  .report-actions a, .report-actions button {
    font-family: var(--sans); font-size: 0.84rem; font-weight: 600;
    border: 1px solid var(--line); background: var(--panel); color: var(--ink);
    border-radius: 999px; padding: 0.55rem 1.05rem; cursor: pointer;
    box-shadow: 0 2px 10px rgba(20,29,36,0.14); text-decoration: none;
  }
  .report-actions .primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .report-actions a:hover, .report-actions button:hover { filter: brightness(1.06); }
  @media print { .report-actions { display: none; } }
</style>
{% if alphagenome %}{% include "_ag_styles.html.j2" %}{% endif %}
</head>
<body>
<header class="report-head">
  <h1>Variant Annotation Report</h1>
  <div class="meta">
    {{ n_variants }} variant{{ "s" if n_variants != 1 else "" }} &middot;
    GRCh38 &middot; generated {{ generated }}
  </div>
</header>

{% if alphagenome %}
<div class="tabs">
  <button class="tab-btn active" data-tab="annot">Annotations</button>
  <button class="tab-btn" data-tab="ag">AlphaGenome</button>
</div>
{% endif %}

<div id="tab-annot" class="tab-panel active">
<div class="wrap">
{% for v in variants %}
  <section class="variant-card">
    <div class="variant-head">
      <span class="coord">{{ v.input.chrom }}:{{ v.input.pos }} {{ v.input.ref }}&rarr;{{ v.input.alt }}</span>
      {% if v.vep.gene_symbol %}<span class="gene">{{ v.vep.gene_symbol }}</span>{% endif %}
      {% if v.vep.most_severe_consequence %}<span class="badge">{{ v.vep.most_severe_consequence|replace("_"," ") }}</span>{% endif %}
      {% if v.vep.mane_select %}<span class="badge">MANE {{ v.vep.mane_select }}</span>{% endif %}
      {% if v.clinvar.found and v.clinvar.clinical_significance %}
        {% set sig = v.clinvar.clinical_significance|lower %}
        <span class="badge {{ 'path' if 'pathogenic' in sig and 'benign' not in sig else ('benign' if 'benign' in sig else '') }}">
          ClinVar: {{ v.clinvar.clinical_significance }}
        </span>
      {% endif %}
    </div>

    <!-- Gene model -->
    <div class="cell" style="border-right:none;">
      <h3>Gene Model</h3>
      {% if v.gene_model and v.gene_model.found %}
        <div class="gene-model">
          {{ v.gene_model.svg | safe }}
          <div class="cap">
            <span>{{ v.gene_model.caption }}</span>
            <span class="pos">{{ v.input.chrom }}:{{ "{:,}".format(v.input.pos) }}{% if v.vep.gene_symbol %} &middot; {{ v.vep.gene_symbol }}{% endif %}{% if v.vep.transcript_id %} &middot; {{ v.vep.transcript_id }}{% endif %}</span>
          </div>
          <div class="legend">
            <span class="sw" style="background:var(--accent)"></span>coding exon
            <span class="sw" style="background:var(--accent-soft); border:1px solid var(--line)"></span>UTR
            <span class="sw" style="background:var(--warn)"></span>variant
          </div>
        </div>
      {% else %}
        <div class="empty">Gene model unavailable{% if v.gene_model and v.gene_model.error %} <span class="err">({{ v.gene_model.error }})</span>{% endif %}</div>
      {% endif %}
    </div>

    <!-- Protein domains -->
    <div class="cell" style="border-right:none; border-top:1px solid var(--line);">
      <h3>Protein Domains</h3>
      {% if v.protein_diagram and v.protein_diagram.found %}
        <div class="gene-model">
          {{ v.protein_diagram.svg | safe }}
          <div class="cap">
            <span>{{ v.protein_diagram.caption }}</span>
            {% if v.vep.hgvsp %}<span class="pos">{{ v.vep.hgvsp }}</span>{% endif %}
          </div>
          {% if v.protein_diagram.domains %}
          <div class="legend">
            {% for d in v.protein_diagram.domains %}<span style="margin-right:0.7rem; white-space:nowrap;"><span class="sw" style="background:{{ d.color }}"></span>{{ d.name }}</span>{% endfor %}
          </div>
          {% endif %}
        </div>
      {% else %}
        <div class="empty">Protein diagram unavailable{% if v.protein_diagram and v.protein_diagram.error %} <span class="err">({{ v.protein_diagram.error }})</span>{% endif %}</div>
      {% endif %}
    </div>

    <div class="grid">

      <!-- HGVS -->
      <div class="cell">
        <h3>HGVS Nomenclature</h3>
        <div class="hgvs">
          {% if v.vep.hgvsg %}<div><span style="color:var(--ink-soft)">g.</span> {{ v.vep.hgvsg }}</div>{% endif %}
          {% if v.vep.hgvsc %}<div><span style="color:var(--ink-soft)">c.</span> {{ v.vep.hgvsc }}</div>{% endif %}
          {% if v.vep.hgvsp %}<div><span style="color:var(--ink-soft)">p.</span> {{ v.vep.hgvsp }}</div>{% endif %}
          {% if not v.vep.hgvsg and not v.vep.hgvsc %}<div class="empty">No HGVS returned</div>{% endif %}
        </div>
        {% if v.vep.transcript_id %}
          <div class="kv" style="margin-top:0.5rem"><span class="k">Transcript</span><span class="v">{{ v.vep.transcript_id }}</span></div>
        {% endif %}
        {% if v.vep.exon %}<div class="kv"><span class="k">Exon</span><span class="v">{{ v.vep.exon }}</span></div>{% endif %}
        {% if v.vep.intron %}<div class="kv"><span class="k">Intron</span><span class="v">{{ v.vep.intron }}</span></div>{% endif %}
      </div>

      <!-- Conservation -->
      <div class="cell">
        <h3>Conservation</h3>
        {% if v.conservation_score is not none %}
          <div class="kv"><span class="k">Score (GERP/PhyloP)</span><span class="v">{{ "%.3f"|format(v.conservation_score) }}</span></div>
        {% endif %}
        {% if v.conservation.available and v.conservation.track %}
          {% if v.conservation.human_aa %}
            <div class="kv"><span class="k">Human residue</span><span class="v">{{ v.conservation.human_aa }}</span></div>
          {% endif %}
          <div class="track">
            {% for ch in v.conservation.track %}<span class="{{ 'g' if ch=='-' else ('m' if ch==v.conservation.human_aa else 'x') }}">{{ ch }}</span>{% endfor %}
          </div>
          <div class="track-legend">amino acid per species (UCSC multiz46way, hg19) &middot; <span style="color:var(--match)">same as human</span> / <span style="color:var(--mismatch)">substitution</span> / - gap &middot; {{ v.conservation.n_species }} species</div>
        {% else %}
          <div class="empty">{{ v.conservation.note or "Protein conservation track unavailable" }}</div>
        {% endif %}
      </div>

      <!-- gnomAD variant -->
      <div class="cell">
        <h3>gnomAD (v4)</h3>
        {% if v.gnomad.found %}
          <div class="kv"><span class="k">Homozygotes</span><span class="v">{{ v.gnomad.total_hom }}</span></div>
          <div class="kv"><span class="k">Heterozygotes</span><span class="v">{{ v.gnomad.total_het }}</span></div>
          <div class="kv"><span class="k">Allele count</span><span class="v">{{ v.gnomad.total_ac }} / {{ v.gnomad.total_an }}</span></div>
          {% if v.gnomad.af is not none %}<div class="kv"><span class="k">Allele freq</span><span class="v">{{ "%.2e"|format(v.gnomad.af) }}</span></div>{% endif %}
        {% else %}
          <div class="empty">Not observed in gnomAD{% if v.gnomad.error %} <span class="err">({{ v.gnomad.error }})</span>{% endif %}</div>
        {% endif %}
        <div class="kv" style="margin-top:0.4rem"><span class="k"></span><span class="v"><a href="{{ v.gnomad.browser_url }}" target="_blank">View in gnomAD &rarr;</a></span></div>
      </div>

      <!-- AlphaMissense -->
      <div class="cell">
        <h3>AlphaMissense</h3>
        {% if v.vep.alphamissense_score is not none %}
          <div class="kv"><span class="k">Pathogenicity</span><span class="v">{{ "%.3f"|format(v.vep.alphamissense_score) }}</span></div>
          {% if v.vep.alphamissense_class %}
            <div class="kv"><span class="k">Class</span><span class="v">{{ v.vep.alphamissense_class }}</span></div>
          {% endif %}
          <div class="score-bar {{ 'path' if v.vep.alphamissense_score > 0.564 else '' }}">
            <span style="width: {{ (v.vep.alphamissense_score * 100)|round }}%"></span>
          </div>
        {% else %}
          <div class="empty">No AlphaMissense score (non-missense or unscored)</div>
        {% endif %}
      </div>

      <!-- REVEL -->
      <div class="cell">
        <h3>REVEL</h3>
        {% if v.revel.found and v.revel.revel is not none %}
          <div class="kv">
            <span class="k">Score</span>
            <span class="v">{{ "%.3f"|format(v.revel.revel) }}{% if v.revel.interpretation %} &middot; {{ v.revel.interpretation }}{% endif %}</span>
          </div>
          <div class="score-bar {{ 'path' if v.revel.revel >= 0.5 else '' }}">
            <span style="width: {{ (v.revel.revel * 100)|round }}%"></span>
          </div>
          {% if v.revel.cadd_phred is not none %}
            <div class="kv" style="margin-top:0.4rem"><span class="k">CADD (phred)</span><span class="v">{{ "%.1f"|format(v.revel.cadd_phred) }}</span></div>
          {% endif %}
        {% elif v.revel.cadd_phred is not none %}
          <div class="empty">No REVEL (non-missense)</div>
          <div class="kv" style="margin-top:0.3rem"><span class="k">CADD (phred)</span><span class="v">{{ "%.1f"|format(v.revel.cadd_phred) }}</span></div>
        {% else %}
          <div class="empty">No REVEL score{% if v.revel.error %} <span class="err">({{ v.revel.error }})</span>{% endif %}</div>
        {% endif %}
      </div>

      <!-- SpliceAI -->
      <div class="cell">
        <h3>SpliceAI</h3>
        {% if not v.spliceai.enabled %}
          <div class="empty">Not run (enable with --spliceai)</div>
        {% elif v.spliceai.found %}
          {% if v.spliceai.max_delta is not none %}
            <div class="kv">
              <span class="k">Max delta (DS)</span>
              <span class="v">{{ "%.2f"|format(v.spliceai.max_delta) }}{% if v.spliceai.interpretation %} &middot; {{ v.spliceai.interpretation }}{% endif %}</span>
            </div>
            <div class="score-bar {{ 'path' if v.spliceai.max_delta >= 0.5 else '' }}">
              <span style="width: {{ (v.spliceai.max_delta * 100)|round }}%"></span>
            </div>
          {% endif %}
          {% for t in v.spliceai.transcripts %}
            {% set t_max = [t.DS_AG or 0, t.DS_AL or 0, t.DS_DG or 0, t.DS_DL or 0]|max %}
            {% if t_max >= 0.2 %}
              <div class="kv" style="margin-top:0.4rem">
                <span class="k">{{ t.symbol or "transcript" }}</span>
                <span class="v">AG {{ "%.2f"|format(t.DS_AG or 0) }} &middot; AL {{ "%.2f"|format(t.DS_AL or 0) }} &middot; DG {{ "%.2f"|format(t.DS_DG or 0) }} &middot; DL {{ "%.2f"|format(t.DS_DL or 0) }}</span>
              </div>
            {% endif %}
          {% endfor %}
          {% if v.spliceai.web_url %}
            <div class="kv" style="margin-top:0.4rem"><span class="k"></span><span class="v"><a href="{{ v.spliceai.web_url }}" target="_blank">View in SpliceAI-lookup &rarr;</a></span></div>
          {% endif %}
        {% else %}
          <div class="empty">No SpliceAI score{% if v.spliceai.error %} <span class="err">({{ v.spliceai.error }})</span>{% endif %}</div>
        {% endif %}
      </div>

      <!-- ClinVar -->
      <div class="cell">
        <h3>ClinVar</h3>
        {% if v.clinvar.found %}
          <div class="kv"><span class="k">Classification</span><span class="v">{{ v.clinvar.clinical_significance or "—" }}</span></div>
          {% if v.clinvar.review_status %}<div class="kv"><span class="k">Review status</span><span class="v">{{ v.clinvar.review_status }}</span></div>{% endif %}
          {% if v.clinvar.n_submissions %}<div class="kv"><span class="k">Submissions</span><span class="v">{{ v.clinvar.n_submissions }}</span></div>{% endif %}
          {% if v.clinvar.url %}<div class="kv" style="margin-top:0.4rem"><span class="k"></span><span class="v"><a href="{{ v.clinvar.url }}" target="_blank">View in ClinVar &rarr;</a></span></div>{% endif %}
        {% else %}
          <div class="empty">Not found in ClinVar{% if v.clinvar.error %} <span class="err">({{ v.clinvar.error }})</span>{% endif %}</div>
        {% endif %}
      </div>

      <!-- Gene constraint -->
      <div class="cell">
        <h3>Gene Constraint (gnomAD)</h3>
        {% if v.constraint.found %}
          {% if v.constraint.pli is not none %}<div class="kv"><span class="k">pLI</span><span class="v">{{ "%.3f"|format(v.constraint.pli) }}</span></div>{% endif %}
          {% if v.constraint.mis_z is not none %}<div class="kv"><span class="k">Missense Z</span><span class="v">{{ "%.2f"|format(v.constraint.mis_z) }}</span></div>{% endif %}
          {% if v.constraint.oe_lof_upper is not none %}<div class="kv"><span class="k">LOEUF</span><span class="v">{{ "%.3f"|format(v.constraint.oe_lof_upper) }}</span></div>{% endif %}
          {% if v.constraint.lof_z is not none %}<div class="kv"><span class="k">pLoF Z</span><span class="v">{{ "%.2f"|format(v.constraint.lof_z) }}</span></div>{% endif %}
          {% if v.constraint.browser_url %}<div class="kv" style="margin-top:0.4rem"><span class="k"></span><span class="v"><a href="{{ v.constraint.browser_url }}" target="_blank">View in gnomAD &rarr;</a></span></div>{% endif %}
        {% else %}
          <div class="empty">No constraint data for gene</div>
        {% endif %}
      </div>

      <!-- GTEx expression -->
      <div class="cell" style="grid-column: 1 / -1; border-right:none;">
        <h3>GTEx Expression &middot; median TPM (v8)</h3>
        {% if v.gtex and v.gtex.found %}
          <table class="gtex">
            {% for t in v.gtex.tissues %}
            <tr class="{{ 'top' if t.top else 'extra' }}">
              <td class="tname">{{ t.name }}{% if not t.top %} <span class="tag">added</span>{% endif %}</td>
              <td class="tbar">
                <div class="gbar"><span class="{{ 'top' if t.top else '' }}" style="width: {{ ((t.median / v.gtex.max_median) * 100)|round(1) }}%"></span></div>
              </td>
              <td class="tval">{{ "%.1f"|format(t.median) }}</td>
            </tr>
            {% endfor %}
          </table>
          <div class="track-legend">Top {{ v.gtex.tissues|selectattr("top")|list|length }} tissues by median expression; muscle, fibroblast and blood always shown</div>
          {% if v.gtex.url %}<div class="kv" style="margin-top:0.4rem"><span class="k"></span><span class="v"><a href="{{ v.gtex.url }}" target="_blank">View in GTEx &rarr;</a></span></div>{% endif %}
        {% else %}
          <div class="empty">No GTEx data{% if v.gtex and v.gtex.error %} <span class="err">({{ v.gtex.error }})</span>{% endif %}</div>
          {% if v.gtex and v.gtex.url %}<div class="kv" style="margin-top:0.4rem"><span class="k"></span><span class="v"><a href="{{ v.gtex.url }}" target="_blank">View in GTEx &rarr;</a></span></div>{% endif %}
        {% endif %}
      </div>

      <!-- OMIM -->
      <div class="cell" style="grid-column: 1 / -1; border-right:none;">
        <h3>OMIM</h3>
        {% if v.omim.found %}
          <div class="kv"><span class="k">Gene MIM</span><span class="v"><a href="{{ v.omim.gene_url }}" target="_blank">{{ v.omim.gene_mim }}</a></span></div>
          {% if v.omim.phenotypes %}
            <table class="pheno">
              {% for p in v.omim.phenotypes %}
              <tr>
                <td>{{ p.phenotype }}</td>
                <td>{{ p.inheritance }}{% if p.mim %} &middot; MIM {{ p.mim }}{% endif %}</td>
              </tr>
              {% endfor %}
            </table>
          {% else %}
            <div class="empty">No associated phenotypes listed</div>
          {% endif %}
        {% else %}
          <div class="empty">No OMIM entry{% if v.omim.error %} <span class="err">({{ v.omim.error }})</span>{% endif %}</div>
        {% endif %}
      </div>

    </div>
  </section>
{% endfor %}
</div>
</div>

{% if alphagenome %}
<div id="tab-ag" class="tab-panel">
<div class="wrap">
{% include "_ag_panel.html.j2" %}
</div>
</div>
{% endif %}

{% if web %}
<div class="report-actions" id="report-actions">
  <a href="/">&larr; New variants</a>
  <button type="button" class="primary" id="dl-btn">Download HTML</button>
</div>
{% endif %}

<footer>
  Generated by varannot &middot; Data: Ensembl VEP, gnomAD v4, NCBI ClinVar, OMIM, UCSC &middot;
  Annotations are for research use and require expert review.
</footer>

{% if alphagenome %}
{% include "_ag_lightbox.html.j2" %}
<script>
  (function () {
    document.querySelectorAll('.tab-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        document.querySelectorAll('.tab-btn').forEach(function (b) { b.classList.remove('active'); });
        document.querySelectorAll('.tab-panel').forEach(function (p) { p.classList.remove('active'); });
        btn.classList.add('active');
        var panel = document.getElementById('tab-' + btn.dataset.tab);
        if (panel) panel.classList.add('active');
      });
    });
  })();
</script>
{% endif %}

{% if web %}
<script id="dl-script">
  (function () {
    var btn = document.getElementById('dl-btn');
    if (!btn) return;
    btn.addEventListener('click', function () {
      // Serialize the page minus the floating toolbar and this script, so the
      // downloaded file is a clean, self-contained copy of the report.
      var clone = document.documentElement.cloneNode(true);
      ['#report-actions', '#dl-script'].forEach(function (sel) {
        var el = clone.querySelector(sel);
        if (el) el.remove();
      });
      var html = '<!DOCTYPE html>\n' + clone.outerHTML;
      var blob = new Blob([html], { type: 'text/html' });
      var url = URL.createObjectURL(blob);
      var a = document.createElement('a');
      a.href = url;
      a.download = 'varannot_report.html';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      setTimeout(function () { URL.revokeObjectURL(url); }, 1000);
    });
  })();
</script>
{% endif %}
</body>
</html>

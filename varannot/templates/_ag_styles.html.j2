    border: 1px solid var(--line); border-radius: 6px; background: #fff; color: var(--ink);
    max-width: 100%;
  }
  .ag-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(440px, 1fr));
    gap: 1rem; margin-top: 1rem;
  }
